generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== ENUM ==========
enum Role {
  user
  admin
  gym_admin
  gym_setter
  gym_moderator
  community_moderator
}

enum Level {
  newbie
  regular
  hallenOG
}

//TODO: change to model
enum Language {
  de
  en
}

enum GymType {
  bouldering
  climbing
  mixed
  }

enum GradeSystemType {
  numeric
  french
  american
  colorBased
  uiaa
}

enum WallType {
  overhang
  slab
  vertical
  roof
}

enum EventType {
  competition
  communityEvent
  communityNight
  party
}

enum ValidationStatus {
  pending
  approved
  rejected
}

enum Status {
  project
  flash
  top
}

enum GradeRating {
  easy
  appropriate
  hard
}

enum QualityRating {
  liked
  neutral
  disliked
}

enum ActivityType {
  boulderUploaded
  boulderValidated
  boulderClimbed
  boulderRated
}

enum RelatedEntityType {
  boulder
  rating
  validation
  userBoulder
}

enum Validation {
  approve
  reject
}

// ========== MODEL ==========
// ========== USER & AUTH ==========
model User {
  id                 String              @id @default(cuid())
  username           String              @unique
  email              String              @unique
  passwordHash       String
  name               String
  surname            String?
  bio                String?
  profilePicture     String?
  city               String
  favoriteGymId      String?
  quarantinedUntil   DateTime?
  role               Role                @default(user)
  experiencePoints   Int                 @default(0)
  level              Level               @default(newbie)
  preferredLanguage  Language            @default(en)
  darkModeEnabled    Boolean             @default(false)
  profileVisibility  Boolean             @default(true)
  emailVerified      Boolean             @default(false)
  favoriteGym        Gym?                @relation("favoriteByUsers", fields: [favoriteGymId], references: [id])
  setBoulders        Boulder[]           @relation("verifiedSetter")
  uploadedBoulders   Boulder[]           @relation("uploadedBy")
  communityRatings   Rating[]
  boulderValidations BoulderValidation[]
  userGymStandings   UserGymStanding[]
  userGymRoles       UserGymRole[]
  userBoulders       UserBoulder[]
  userArchives       UserArchive[]
  events             Event[]
  walls              Wall[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastLoginAt        DateTime            @default(now())
  RefreshToken       RefreshToken[]
}

// ========== LOCATION ==========
model Gym {
  id               String            @id @default(cuid())
  adminUserId      String?
  name             String
  type             GymType
  address          Json
  city             String
  website          String
  phone            String
  email            String
  openingHours     Json
  description      String
  priceInfo        Json
  imageUrl         String?
  gradeSystemType  GradeSystemType
  isActive         Boolean           @default(true)
  walls            Wall[]
  events           Event[]
  favoritedByUsers User[]            @relation("favoriteByUsers")
  userGymStandings UserGymStanding[]
  userGymRoles     UserGymRole[]
  grades           Grade[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([name, city, email])
}

model Wall {
  id          String     @id @default(cuid())
  gymId       String
  createdById String
  name        String
  description String
  imageUrl    String?
  wallType    WallType[]
  isActive    Boolean
  lastReset   DateTime
  gym         Gym        @relation(fields: [gymId], references: [id])
  createdBy   User       @relation(fields: [createdById], references: [id])
  boulders    Boulder[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model UserGymStanding {
  userId      String
  gymId       String
  trustPoints Int    @default(0)
  user        User   @relation(fields: [userId], references: [id])
  gym         Gym    @relation(fields: [gymId], references: [id])

  @@unique([userId, gymId])
}

model UserGymRole {
  userId         String
  gymId          String
  role           Role
  grantedAt      DateTime  @default(now())
  grantedBy      String
  source         String
  status         String
  lastActivityAt DateTime?
  expiresAt      DateTime?

  user User @relation(fields: [userId], references: [id])
  gym  Gym  @relation(fields: [gymId], references: [id])

  @@unique([userId, gymId, role])
}

// ========== REFERENCE DATA ==========
model Color {
  id        String    @id @default(cuid())
  name      String
  hexCode   String
  boulders  Boulder[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Event {
  id               String      @id @default(cuid())
  gymId            String
  createdById      String
  title            String
  eventType        EventType[]
  description      String
  imageUrl         String?
  startTime        String
  endTime          String
  price            String
  registrationLink String
  isActive         Boolean
  gym              Gym         @relation(fields: [gymId], references: [id])
  createdBy        User        @relation(fields: [createdById], references: [id])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Grade {
  id           String    @id @default(cuid())
  gymId        String
  value        String
  displayOrder Int
  gym          Gym       @relation(fields: [gymId], references: [id])
  boulders     Boulder[]
  createdAt    DateTime  @default(now())

  @@unique([gymId, value])
  @@unique([gymId, displayOrder])
}

// ========== BOULDER & VALIDATION ==========
model Boulder {
  id                       String              @id @default(cuid())
  wallId                   String
  name                     String?
  setGradeId               String
  communityGrade           GradeRating
  communityFeedback        QualityRating
  verifiedSetterId         String?
  unverifiedSetterName     String?
  uploadedById             String
  status                   ValidationStatus
  imageUrl                 String?
  requiredValidationPoints Int
  currentValidationPoints  Int
  wall                     Wall                @relation(fields: [wallId], references: [id])
  setGrade                 Grade               @relation(fields: [setGradeId], references: [id])
  colors                   Color[]
  verifiedSetter           User?               @relation("verifiedSetter", fields: [verifiedSetterId], references: [id])
  uploadedBy               User                @relation("uploadedBy", fields: [uploadedById], references: [id])
  communityRatings         Rating[]
  boulderValidations       BoulderValidation[]
  climbedBy                UserBoulder[]
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
}

model BoulderValidation {
  id                  String     @id @default(cuid())
  boulderId           String
  userId              String
  validation          Validation
  validationPowerUsed Int
  rejectReason        String?
  boulder             Boulder    @relation(fields: [boulderId], references: [id])
  user                User       @relation(fields: [userId], references: [id])
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([boulderId, userId])
}

// ========== USER INTERACTIONS ==========
model UserBoulder {
  id             String    @id @default(cuid())
  boulderId      String
  userId         String
  status         Status
  attempts       Int
  firstAttemptAt DateTime
  completedAt    DateTime?
  xpAwarded      Int
  boulder        Boulder   @relation(fields: [boulderId], references: [id])
  user           User      @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([boulderId, userId])
}

model Rating {
  id            String        @id @default(cuid())
  boulderId     String
  userId        String
  gradeRating   GradeRating
  qualityRating QualityRating
  comment       String?
  boulder       Boulder       @relation(fields: [boulderId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([boulderId, userId])
}

model UserArchive {
  id                String            @id @default(cuid())
  userId            String
  gymId             String?
  activityType      ActivityType
  xpGained          Int
  relatedEntityType RelatedEntityType
  relatedEntityId   String
  user              User              @relation(fields: [userId], references: [id])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model SetterPromotion {
  id String @id
  // TODO: Add fields later
}

model SetterPromotionVote {
  id String @id
  // TODO: Add fields later
}

model Report {
  id String @id
  // TODO: Add fields later
}
