// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/generated/prisma"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ========== ENUM ==========
enum Role {
  User
  Moderator
  Admin
}

enum Level {
  Newbie
  Regular
  HallenOG
}

enum Language {
  De
  En
}

enum gradeSystemType {
  numeric
  french
  american
  colorBased
}

// ========== MODEL ==========
model User {
  id                String   @id @default(cuid())
  username          String   @unique
  email             String   @unique
  passwordHash      String
  name              String
  surname           String?
  bio               String?
  profilePicture    String
  city              String
  favoriteGym       Gym?     @relation("favoriteByUsers", fields: [favoriteGymId], references: [id])
  favoriteGymId     String?
  role              Role
  experiencePoints  Int
  level             Level
  trustPoints       Int
  validationPower   Int
  preferredLanguage Language
  darkModeEnabled   Boolean
  profileVisibility Boolean
  emailVerified     Boolean
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastLoginAt       DateTime @default(now())
}

model Gym {
  id               String          @id @default(cuid())
  name             String
  adress           Json
  city             String
  website          String
  phone            String
  email            String
  openingHours     Json
  description      String
  priceInfo        Json
  image            String
  gradeSystemType  gradeSystemType
  isActive         Boolean
  favoritedByUsers User[]          @relation("favoriteByUsers")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}
